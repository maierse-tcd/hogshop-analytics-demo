{
  "name": "playwright-hedgehog-bots",
  "version": "1.0.0",
  "description": "Realistic Playwright bots for HogShop e-commerce demo",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "bots:start": "tsx scripts/backgroundBots.ts",
    "bots:test": "playwright test --headed --workers=1",
    "db:init": "sqlite3 database/hedgehog_bots.db < database/schema.sql && sqlite3 database/hedgehog_bots.db < database/seeds.sql",
    "users:create": "tsx scripts/userGenerator.ts --run-once",
    "churn:test": "tsx scripts/churnEngine.ts --test",
    "churn:process": "tsx scripts/churnEngine.ts --process",
    "test:journey": "playwright test tests/"
  },
  "keywords": ["playwright", "automation", "e-commerce", "posthog"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "@faker-js/faker": "^9.3.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.2"
  }
}
