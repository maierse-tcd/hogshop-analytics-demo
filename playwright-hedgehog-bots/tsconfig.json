{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "@types/better-sqlite3"]
  },
  "include": [
    "lib/**/*",
    "scripts/**/*",
    "tests/**/*",
    "database/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
