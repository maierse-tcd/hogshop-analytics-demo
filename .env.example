# PostHog Configuration
# Get your API key from https://app.posthog.com/project/settings (or https://eu.posthog.com for EU)
VITE_POSTHOG_KEY=your_posthog_project_api_key
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Alternative naming (for Next.js compatibility)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Supabase Configuration (Auto-generated by Lovable Cloud)
VITE_SUPABASE_URL=auto_generated
VITE_SUPABASE_PUBLISHABLE_KEY=auto_generated
VITE_SUPABASE_PROJECT_ID=auto_generated

# PostHog source-map upload (used by `npm run build:with-sourcemaps` in CI).
# Create a personal API token + locate your env ID:
# https://posthog.com/docs/error-tracking/upload-source-maps
# Required for PostHog source-map upload (set in Lovable build env)
POSTHOG_CLI_TOKEN=
POSTHOG_CLI_ENV_ID=
